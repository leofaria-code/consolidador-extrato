{
  "info": {
    "name": "Consolidador de Extrato - Observabilidade - Carga continua",
    "description": "Colecao para rodar no Collection Runner com 5-20 iteracoes e delay entre requests. Gera ids dinamicos por iteracao, percorre o fluxo feliz e consulta sinais de observabilidade no Prometheus. Se sua stack de observabilidade estiver em portas customizadas, ajuste `urlPrometheus` antes de rodar.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "urlIngestao",
      "value": "http://localhost:8081"
    },
    {
      "key": "urlConsulta",
      "value": "http://localhost:8083"
    },
    {
      "key": "urlPrometheus",
      "value": "http://localhost:9090"
    },
    {
      "key": "competencia",
      "value": "2026-07"
    },
    {
      "key": "clienteBase",
      "value": "cliente-observabilidade"
    },
    {
      "key": "clienteAtual",
      "value": ""
    },
    {
      "key": "lancamentoAtual",
      "value": ""
    },
    {
      "key": "correlacaoAtual",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "0 - Prometheus UP",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Prometheus respondeu com sucesso', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('success');",
              "});",
              "pm.test('targets principais estao UP', function () {",
              "  var resultados = pm.response.json().data.result;",
              "  var porJob = {};",
              "  resultados.forEach(function (item) { porJob[item.metric.job] = item.value[1]; });",
              "  pm.expect(porJob.ingestao).to.eql('1');",
              "  pm.expect(porJob.consolidacao).to.eql('1');",
              "  pm.expect(porJob.consulta).to.eql('1');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{urlPrometheus}}/api/v1/query?query=up"
      }
    },
    {
      "name": "1 - POST lancamento observavel",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var iteration = pm.info.iteration || 0;",
              "var suffix = String(Date.now()) + '-' + iteration;",
              "pm.collectionVariables.set('clienteAtual', pm.collectionVariables.get('clienteBase') + '-' + suffix);",
              "pm.collectionVariables.set('lancamentoAtual', 'lanc-observabilidade-' + suffix);",
              "pm.collectionVariables.set('correlacaoAtual', 'corr-observabilidade-' + suffix);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('aceite assincrono retornou 202', function () {",
              "  pm.response.to.have.status(202);",
              "});",
              "pm.test('correlation id foi ecoado', function () {",
              "  pm.expect(pm.response.headers.get('X-Correlation-Id')).to.eql(pm.collectionVariables.get('correlacaoAtual'));",
              "});",
              "pm.test('identidade devolvida bate com o request atual', function () {",
              "  var corpo = pm.response.json();",
              "  pm.expect(corpo.status).to.eql('ACEITO');",
              "  pm.expect(corpo.identidade.idLancamentoOrigem).to.eql(pm.collectionVariables.get('lancamentoAtual'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Correlation-Id",
            "value": "{{correlacaoAtual}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"idCliente\": \"{{clienteAtual}}\",\n  \"idLancamentoOrigem\": \"{{lancamentoAtual}}\",\n  \"instituicaoOrigem\": \"banco-observabilidade\",\n  \"agencia\": \"0099\",\n  \"conta\": \"99001-1\",\n  \"tipo\": \"CREDITO\",\n  \"valor\": 25.50,\n  \"moeda\": \"BRL\",\n  \"dataHoraOcorrencia\": \"{{competencia}}-11T10:15:00-03:00\",\n  \"idConsentimento\": \"consent-observabilidade\",\n  \"descricao\": \"carga continua observavel\",\n  \"categoriaOrigem\": \"transferencia\"\n}"
        },
        "url": "{{urlIngestao}}/lancamentos"
      }
    },
    {
      "name": "2 - GET extrato forcando atualizacao",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('consulta respondeu 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('saldo e entradas refletem o credito enviado', function () {",
              "  var corpo = pm.response.json();",
              "  pm.expect(corpo.idCliente).to.eql(pm.collectionVariables.get('clienteAtual'));",
              "  pm.expect(Number(corpo.totais.entradas)).to.eql(25.5);",
              "  pm.expect(Number(corpo.totais.saldo)).to.eql(25.5);",
              "  pm.expect(corpo.atualizadoEm).to.not.be.null;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{urlConsulta}}/extrato/{{clienteAtual}}/{{competencia}}?atualizar=true"
      }
    },
    {
      "name": "3 - Prometheus - lancamentos publicados",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('metrica de publicacao esta exposta', function () {",
              "  pm.response.to.have.status(200);",
              "  var resultados = pm.response.json().data.result;",
              "  pm.expect(resultados.length).to.be.above(0);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{urlPrometheus}}/api/v1/query?query=extrato_ingestao_lancamentos_publicados_total"
      }
    },
    {
      "name": "4 - Prometheus - consolidacao incorporado ou repetido",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('metrica da consolidacao esta presente', function () {",
              "  pm.response.to.have.status(200);",
              "  var resultados = pm.response.json().data.result;",
              "  var labels = resultados.map(function (item) { return item.metric.resultado; });",
              "  pm.expect(labels.length).to.be.above(0);",
              "  pm.expect(labels.join(',')).to.match(/incorporado|repetido/);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{urlPrometheus}}/api/v1/query?query=extrato_consolidacao_lancamentos_total"
      }
    },
    {
      "name": "5 - Prometheus - cache hit e miss",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('metrica do cache esta presente', function () {",
              "  pm.response.to.have.status(200);",
              "  var resultados = pm.response.json().data.result;",
              "  var labels = resultados.map(function (item) { return item.metric.result; });",
              "  pm.expect(labels).to.include('miss');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{urlPrometheus}}/api/v1/query?query=cache_gets_total{cache=\"extrato-consolidado\"}"
      }
    }
  ]
}
