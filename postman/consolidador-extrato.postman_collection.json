      "name": "7 · Stack completa por padrão: broadcast entre réplicas + observabilidade (ADR-006 nota / ADR-008 rev. 11-07)",
      "item": [
        {
          "name": "Health — réplica da consulta (8084)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
